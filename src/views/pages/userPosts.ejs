<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
      <link
      rel="stylesheet"
      href="/css/output.css"
    />
</head>
<body class="bg-black text-neutral-200 m-4">
  <%- include("../partials/navbar") %>   
  <main>
      <section class="m-4">
            <h1 class="mb-2">Your Posts</h1>
            <% if(posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <article class="p-4 rounded-md border-2 border-neutral-200 w-full my-2">
                        <div class="flex gap-2 items-center">
                            <div class="rounded-full w-8 h-8" role="img" aria-label="Profile avatar for <%= post.author.username %>"  <% /* eslint-disable css-propertyvalueexpected */ %> style="background-image: <%= post.author.profile %>"></div>
                            <div class=" <%= currentUser && currentUser.membership ? '' : 'blur-xs' %>">
                                <p><%= post.author.username %></p>
                                <p class="text-xs text-neutral-500">
                                    <%= formatDate(post.createdAt) %>
                                </p>
                            </div>
                            <form action="/post/<%= post._id %>" method="POST" class="ml-auto">
                            <button type="submit" aria-label="Delete post from <%= formatDate(post.createdAt) %>" class="hover:cursor-pointer text-xs text-red-800 hover:text-red-600">DELETE</button>
                            </form>
      
                        </div>
                        <div class="mt-4">
                            <p><%= post.content %></p>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <p>No posts yet.</p>
            <% } %>
         </section>
  </main>
</body>
</html>